# =============================================================
# Hale-Bopp DB — Agentic Observer LLM Configuration
# Bring Your Own LLM (BYOL) — mirroring Valentino Engine pattern
# =============================================================
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# --- Provider Selection ---
# Options: openrouter | azure | ollama
HBDB_LLM_PROVIDER=openrouter

# --- OpenRouter (default) ---
HBDB_LLM_API_KEY=your_openrouter_api_key_here
HBDB_LLM_MODEL=anthropic/claude-haiku-4-5
# HBDB_LLM_BASE_URL=https://openrouter.ai/api/v1

# --- Azure OpenAI (enterprise) ---
# HBDB_LLM_PROVIDER=azure
# HBDB_LLM_API_KEY=your_azure_api_key
# HBDB_LLM_BASE_URL=https://<resource>.openai.azure.com/openai/deployments/<deployment-id>
# HBDB_AZURE_API_VERSION=2024-02-15-preview

# --- Ollama (on-premise / bare-metal — zero data leaves the server) ---
# HBDB_LLM_PROVIDER=ollama
# HBDB_LLM_MODEL=llama3
# HBDB_LLM_BASE_URL=http://localhost:11434

# --- Tuning ---
HBDB_LLM_MAX_TOKENS=2048
HBDB_LLM_TEMPERATURE=0.2
